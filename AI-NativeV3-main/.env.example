# Config general
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=json

# ────────── PostgreSQL ──────────
# Usuarios separados por plano (ADR-003)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# academic_main (plano académico)
ACADEMIC_DB_URL=postgresql+asyncpg://academic_user:academic_pass@localhost:5432/academic_main

# ctr_store (CTR + clasificaciones)
CTR_DB_URL=postgresql+asyncpg://ctr_user:ctr_pass@localhost:5432/ctr_store

# identity_store removed in session 2026-04-21 (BUG-25 Option A).
# Identidad federada vía Keycloak; pseudonimización en packages/platform-ops/privacy.py.

# ────────── Keycloak ──────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM_PLATFORM=platform
KEYCLOAK_REALM_DEMO=demo_uni

# ────────── Redis (bus + cache) ──────────
REDIS_URL=redis://localhost:6379/0
REDIS_STREAMS_MAXLEN=1000000

# ────────── MinIO / S3 (storage) ──────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MATERIALS=materials
S3_BUCKET_ARCHIVE=ctr-archive
S3_REGION=us-east-1

# ────────── LLM providers (vía ai-gateway) ──────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME
VOYAGE_API_KEY=pa-REPLACE_ME

# Defaults de modelos
TUTOR_MODEL=claude-sonnet-4-6
CLASSIFIER_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANKER_MODEL=BAAI/bge-reranker-base

# ────────── Observabilidad ──────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=auto  # cada servicio lo sobreescribe
SENTRY_DSN=

# ────────── Governance ──────────
# Repo Git con prompt versionado (ADR-009)
PROMPTS_REPO_PATH=./ai-native-prompts
GOVERNANCE_REPO_URL=git@github.com:your-org/ai-native-prompts.git
GOVERNANCE_GPG_KEY_ID=

# ────────── Frontends (Vite) ──────────
VITE_API_URL=http://127.0.0.1:8000
VITE_KEYCLOAK_URL=http://127.0.0.1:8180
VITE_KEYCLOAK_REALM=demo_uni
VITE_KEYCLOAK_CLIENT_ID=web-student
VITE_SENTRY_DSN=

# ────────── Seguridad ──────────
JWT_PUBLIC_KEY_PATH=
# secretos de runtime no van acá: usar Vault / Infisical en prod

# Master key para encriptar BYOKKey.encrypted_value (AES-256-GCM, ADR-038).
# Generar en dev con: openssl rand -base64 32
# En prod: Vault/KMS. NUNCA commitear ni loguear el valor.
# Si se pierde, todas las keys BYOK quedan inservibles — rotación obligatoria.
BYOK_MASTER_KEY=

# ────────── Multi-tenant (F5+) ──────────
# ai-gateway: fallback global si el tenant no tiene key propia
# Keys por-tenant: archivo en /etc/platform/llm-keys/{tenant_uuid}/{provider}.key
# o env var LLM_KEY_{TENANT_UUID}_{PROVIDER}
EXPORT_WORKER_SALT=dev_salt_change_in_production_min_16_chars

# ────────── Feature flags (F6+) ──────────
FEATURE_FLAGS_PATH=/etc/platform/feature_flags.yaml
FEATURE_FLAGS_RELOAD_SECONDS=60

# ────────── DB URLs adicionales ──────────
# classifier-service y content-service LOS NECESITAN siempre para funcionar.
# analytics-service los reutiliza para decidir stub vs real (vacío → stub en dev).
# NOTA: el mismo nombre de var es reusado por servicios distintos — deuda del template,
# a separar en ANALYTICS_CLASSIFIER_DB_URL + CLASSIFIER_DB_URL cuando se aborde.
CTR_STORE_URL=postgresql+asyncpg://ctr_user:ctr_pass@localhost:5432/ctr_store
CLASSIFIER_DB_URL=postgresql+asyncpg://classifier_user:classifier_pass@localhost:5432/classifier_db
CONTENT_DB_URL=postgresql+asyncpg://content_user:content_pass@localhost:5432/content_db

# ────────── LDAP federation (F6+) ──────────
# Solo para onboarding UNSL (examples/unsl_onboarding.py)
LDAP_URL=ldaps://ldap.unsl.edu.ar:636
LDAP_BIND_PASSWORD=
TENANT_ADMIN_EMAIL=

# ────────── Backup / Restore ──────────
PG_BACKUP_USER=backup_user
PG_BACKUP_PASSWORD=

# ────────── CI/Testing ──────────
# Si está seteada, corre los tests de RLS contra un Postgres real
CTR_STORE_URL_FOR_RLS_TESTS=postgresql+asyncpg://app_runtime:app_runtime@localhost:5432/ctr_store
