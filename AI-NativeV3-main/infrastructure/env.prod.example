# =============================================================================
# .env.prod — template para piloto-2 ampliado UTN
# =============================================================================
#
# Uso:
#   cp infrastructure/env.prod.example infrastructure/.env.prod
#   # editar .env.prod con secrets reales (NUNCA commitearlo)
#   docker compose -f infrastructure/docker-compose.prod.yml \
#     --env-file infrastructure/.env.prod up -d
#
# Validar con:
#   bash scripts/check-health.sh
#   make test-rls
#
# SECRETS — generar antes del primer deploy:
#   openssl rand -base64 32  # para POSTGRES_PASSWORD, *_DB_PASSWORD, REDIS_PASSWORD, BYOK_MASTER_KEY
#
# =============================================================================
# 1. POSTGRES — root y por base logica (ADR-003)
# =============================================================================

# Root user del cluster Postgres (solo bootstrap).
POSTGRES_PASSWORD=CAMBIAR_GENERAR_CON_openssl_rand_base64_32

# Una password por base logica. Los users (academic_user, ctr_user, etc) se
# crean por init-dbs.sql con passwords hardcoded ahi — ALTER USER en post-init.
ACADEMIC_DB_PASSWORD=CAMBIAR
CTR_DB_PASSWORD=CAMBIAR
CLASSIFIER_DB_PASSWORD=CAMBIAR
CONTENT_DB_PASSWORD=CAMBIAR

# =============================================================================
# 2. KEYCLOAK — auth de produccion (ADR-002)
# =============================================================================

KEYCLOAK_DB_PASSWORD=CAMBIAR

# Admin del realm (consola Keycloak en :8180). Cambiar de admin/admin.
KEYCLOAK_ADMIN_USER=ops_admin
KEYCLOAK_ADMIN_PASSWORD=CAMBIAR

# Hostname publico del Keycloak (sin protocolo). Para piloto local: localhost.
# Para VPS UTN: keycloak.tu-dominio.utn.edu.ar (con TLS reverse proxy).
KEYCLOAK_HOSTNAME=localhost

# Bind del puerto admin de Keycloak. Default 127.0.0.1:8180 — solo loopback.
# Para acceso externo via proxy: 0.0.0.0:8180.
KEYCLOAK_BIND=127.0.0.1:8180

# =============================================================================
# 3. API GATEWAY — auth + CORS + service discovery
# =============================================================================

# JWT validation — DEBEN setearse para que dev_trust_headers quede en False.
# Sin estas, los headers X-* pueden falsificarse.
JWT_ISSUER=http://keycloak:8080/realms/demo_uni
JWT_AUDIENCE=platform-backend
JWT_JWKS_URI=http://keycloak:8080/realms/demo_uni/protocol/openid-connect/certs

# CORS — lista separada por coma de dominios de los frontends.
# NUNCA usar "*" en prod (combinado con cookies de Bearer es bypass total).
CORS_ORIGINS=https://web-student.tu-dominio.utn.edu.ar,https://web-teacher.tu-dominio.utn.edu.ar,https://web-admin.tu-dominio.utn.edu.ar

# Bind del api-gateway. Default 0.0.0.0:8000 — acepta conexiones de la red.
# Detras de reverse-proxy TLS, considerar 127.0.0.1:8000.
API_GATEWAY_BIND=0.0.0.0:8000

# =============================================================================
# 4. REDIS — bus eventos + rate-limit + sessions
# =============================================================================

# Generar con: openssl rand -base64 32
REDIS_PASSWORD=CAMBIAR
REDIS_MAXMEMORY=2gb

# =============================================================================
# 5. MINIO — storage S3 para materiales + archive CTR
# =============================================================================

MINIO_ROOT_USER=platform_prod
MINIO_ROOT_PASSWORD=CAMBIAR

# =============================================================================
# 6. AI-GATEWAY — BYOK master key
# =============================================================================

# Encripta BYOKKey.encrypted_value (AES-256-GCM, ADR-038).
# Generar: openssl rand -base64 32. NUNCA loggear, NUNCA versionar.
# Si la perdes: rotar TODAS las keys BYOK del tenant.
BYOK_MASTER_KEY=CAMBIAR_GENERAR_CON_openssl_rand_base64_32

# =============================================================================
# 7. GRAFANA — observabilidad UI
# =============================================================================

GRAFANA_ADMIN_USER=ops_admin
GRAFANA_ADMIN_PASSWORD=CAMBIAR
GRAFANA_ROOT_URL=http://localhost:3000

# Bind. Default 127.0.0.1:3000 — solo loopback (acceso via SSH tunnel desde VPS).
GRAFANA_BIND=127.0.0.1:3000

# =============================================================================
# 8. OBSERVABILIDAD — log level del stack
# =============================================================================

# info para prod. debug solo para troubleshooting puntual.
LOG_LEVEL=info

# =============================================================================
# 9. ALERTAS (alertmanager) — destinatario de notificaciones
# =============================================================================

# Email del equipo tecnico para alertas criticas (CTR integrity, backup fallido).
# Usado por alertmanager.yml.
ALERTS_EMAIL_TO=equipo-tecnico@utn.edu.ar

# SMTP relay institucional (sin auth si es interno).
ALERTS_SMTP_HOST=smtp.utn.edu.ar
ALERTS_SMTP_PORT=587
ALERTS_SMTP_FROM=noreply-platform@utn.edu.ar
# ALERTS_SMTP_USER=
# ALERTS_SMTP_PASSWORD=

# =============================================================================
# Variables a NO commitear: este archivo es .env.prod.example. Crear
# infrastructure/.env.prod (en .gitignore) con los valores reales.
# =============================================================================
