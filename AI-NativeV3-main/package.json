{
  "name": "platform-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma académica multi-universidad — raíz del monorepo (node workspace)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "e2e:report": "playwright show-report tests/e2e/playwright-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "docx": "^9.6.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "playwright": "^1.59.1",
    "turbo": "^2.2.0",
    "typescript": "~5.6.0"
  }
}
