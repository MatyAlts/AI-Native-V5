{
  "annotations": {
    "list": []
  },
  "description": "SLOs y KPIs clave de la plataforma AI-Native N4",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "title": "Tutor service — Latencia de respuesta",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Tutor SSE — latencia P50/P95/P99",
      "description": "SLO: P95 < 3s (primer token), P99 < 8s. Por encima alerta.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_seconds_bucket{service_name=\"tutor-service\", http_route=~\"/api/v1/episodes/.+/message\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_seconds_bucket{service_name=\"tutor-service\", http_route=~\"/api/v1/episodes/.+/message\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_seconds_bucket{service_name=\"tutor-service\", http_route=~\"/api/v1/episodes/.+/message\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 8}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Episodios abiertos (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_total{service_name=\"tutor-service\", http_route=\"/api/v1/episodes\", http_method=\"POST\", http_status_code=\"201\"}[24h]))",
          "legendFormat": "abiertos"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Episodios clasificados (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_total{service_name=\"classifier-service\", http_route=~\"/api/v1/classify_episode/.+\", http_method=\"POST\", http_status_code=\"200\"}[24h]))"
        }
      ]
    },
    {
      "type": "row",
      "title": "AI Gateway — Budget y caché",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Tokens consumidos por feature",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (feature) (rate(aigw_tokens_total[5m]))",
          "legendFormat": "{{feature}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "type": "timeseries",
      "title": "Cache hit ratio",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "description": "SLO: cache hit rate > 30% en clasificación (temperature=0)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(aigw_cache_hits_total[5m])) / sum(rate(aigw_requests_total{temperature=\"0\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.2},
              {"color": "green", "value": 0.3}
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "CTR — Integridad y throughput",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Eventos persistidos por partición",
      "description": "SLO: un worker por shard consume a ritmo constante",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (partition) (rate(ctr_events_persisted_total[5m]))",
          "legendFormat": "p{{partition}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Episodios integrity_compromised",
      "description": "Objetivo: 0. Cualquier valor > 0 requiere investigación.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 19},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "ctr_episodes_integrity_compromised_total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "DLQ size",
      "description": "Eventos en dead-letter queue. Deberían ser raros.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 19},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "ctr_dlq_size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Clasificación N4 — Distribución",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "collapsed": false
    },
    {
      "type": "piechart",
      "title": "Clasificaciones por tipo (7 días)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (appropriation) (increase(classifier_classifications_total[7d]))",
          "legendFormat": "{{appropriation}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tendencia de apropiación reflexiva (% del total)",
      "description": "Métrica de salud pedagógica. Objetivo: crecer en el tiempo.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(classifier_classifications_total{appropriation=\"apropiacion_reflexiva\"}[1h])) / sum(rate(classifier_classifications_total[1h]))",
          "legendFormat": "% reflexiva"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0, "max": 1}
      }
    },
    {
      "type": "row",
      "title": "API Gateway — Rate limit y errores",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Requests 429 (rate limited) por tier",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_requests_total{service_name=\"api-gateway\", http_status_code=\"429\"}[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate 5xx",
      "description": "SLO: error rate < 1% en ventana de 5 min",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_requests_total{http_status_code=~\"5..\"}[5m])) / sum by (service_name) (rate(http_server_requests_total[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.005},
              {"color": "red", "value": 0.01}
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["platform", "slo"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "Plataforma AI-Native — SLOs",
  "uid": "platform-slos",
  "version": 1
}
